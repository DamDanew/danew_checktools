{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "danew/profile.schema.json",
  "title": "Profile",
  "type": "object",
  "required": ["id", "name", "description", "targets", "required_features", "required_tools"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "targets": { "type": "array", "items": { "type": "string" } },
    "required_features": { "type": "array", "items": { "type": "string" } },
    "required_tools": { "type": "array", "items": { "type": "string" } },
    "recommended_tools": { "type": "array", "items": { "type": "string" } },
    "optional_tools": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
