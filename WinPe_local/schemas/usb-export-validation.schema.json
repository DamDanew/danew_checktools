{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "danew/usb-export-validation.schema.json",
  "title": "UsbExportValidation",
  "type": "object",
  "required": ["ready_for_export", "required_paths", "architecture_consistency"],
  "properties": {
    "ready_for_export": { "type": "boolean" },
    "required_paths": { "type": "array", "items": { "type": "object" } },
    "architecture_consistency": { "type": "boolean" },
    "estimated_size_mb": { "type": "number" },
    "estimated_ram_mb": { "type": "number" }
  },
  "additionalProperties": true
}
